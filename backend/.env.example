# Configuration du serveur
PORT=5000

# Configuration email Proton Mail
# Pour obtenir un mot de passe d'application Proton Mail:
# 1. Connectez-vous à votre compte Proton Mail
# 2. Allez dans Paramètres > Sécurité et confidentialité
# 3. Créez un mot de passe d'application
EMAIL_HOST=smtp.protonmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@proton.me
EMAIL_PASS=votre_mot_de_passe_application

# Note: Renommez ce fichier en .env et remplissez vos informations